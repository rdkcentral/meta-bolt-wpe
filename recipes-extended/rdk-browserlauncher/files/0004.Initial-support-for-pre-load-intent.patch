 #include <glib.h>
 #include <gio/gio.h>
 
+using json = nlohmann::json;
+
+namespace Firebolt
+{
+
+struct Intent
+{
+    std::string action;
+    struct {
+        std::string source;
+    } context;
+};
+
+#define _SAFE_GET(j, name) ((j.is_object() && j.contains(name)) ? j.at(name) : json(nullptr))
+
+void from_json(const json& j, Intent& i)
+{
+    if (j.is_discarded())
+        return;
+    auto action = _SAFE_GET(j, "action");
+    if (!action.is_string())
+        return;
+    action.get_to(i.action);
+    if (action.empty())
+        return;
+    auto context = _SAFE_GET(j, "context");
+    auto source = _SAFE_GET(context, "source");
+    if (!source.is_string()) {
+        i.action.clear();
+        return;
+    }
+    source.get_to(i.context.source);
+}
+
